    "duration_seconds": 15,
    "storyboard": [
      {
        "shot_number": 1,
        "duration": "string: 时间段",
        "visual": "string: 画面内容",
        "subtitle": "string: 屏幕文字",
        "voiceover": "string: 旁白"
      }
    ],
    "cta": "string: 行动号召",
    "material_requirements": ["string: 所需素材"],
    "pacing": "string: 节奏描述"
  }
